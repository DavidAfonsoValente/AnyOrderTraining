% neurips_2024.sty  –  NeurIPS 2024 submission style
% Based on the official NeurIPS style.
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{neurips_2024}[2024/05/01 NeurIPS 2024]

\DeclareOption{final}{\def\@nipsfinal{}}
\DeclareOption{preprint}{\def\@nipspreprint{}}
\DeclareOption{nonatbib}{\def\@nipsnonatbib{}}
\ProcessOptions\relax

% ---- Page geometry ----
\usepackage[
  letterpaper,
  top=1in,
  bottom=1in,
  left=1.25in,
  right=1.25in,
  headheight=14pt,
  headsep=0.25in
]{geometry}

% ---- Fonts ----
\usepackage{times}
\usepackage[T1]{fontenc}

% ---- Paragraph spacing ----
\setlength{\parindent}{0pt}
\setlength{\parskip}{4pt plus 1pt minus 1pt}

% ---- Section headings ----
\usepackage{titlesec}
\titleformat{\section}{\large\bfseries}{\thesection}{1em}{}
\titleformat{\subsection}{\normalsize\bfseries}{\thesubsection}{1em}{}
\titleformat{\subsubsection}{\normalsize\itshape}{\thesubsubsection}{1em}{}
\titlespacing*{\section}{0pt}{8pt plus 2pt minus 2pt}{4pt plus 1pt}
\titlespacing*{\subsection}{0pt}{6pt plus 2pt minus 1pt}{3pt plus 1pt}

% ---- Abstract ----
\renewenvironment{abstract}{%
  \centerline{\large\bfseries Abstract}%
  \vspace{0.4ex}%
  \begin{quote}\small
}{%
  \end{quote}%
  \vspace{1ex}%
}

% ---- Title block ----
\newcommand{\nipstitleblock}{%
  \begin{center}
    {\Large\bfseries \@title \par}
    \vspace{0.5em}
    {\normalsize \@author \par}
    \vspace{0.5em}
    \ifdefined\@nipspreprint
      {\small Preprint. Under review.}
    \else\ifdefined\@nipsfinal
      {}
    \else
      {\small Anonymous authors. Paper under double-blind review.}
    \fi\fi
  \end{center}
  \vspace{0.5em}
}
\renewcommand{\maketitle}{\nipstitleblock}

% ---- Header / footer ----
\usepackage{fancyhdr}
\pagestyle{fancy}
\fancyhf{}
\renewcommand{\headrulewidth}{0pt}
\ifdefined\@nipsfinal
  \fancyhead[C]{\small 38th Conference on Neural Information Processing Systems (NeurIPS 2024).}
\else
  \fancyhead[C]{}
\fi
\fancyfoot[C]{\small\thepage}

% ---- Caption formatting ----
\usepackage[font=small,labelfont=bf,labelsep=period]{caption}
\setlength{\abovecaptionskip}{4pt}
\setlength{\belowcaptionskip}{0pt}

% ---- Floats ----
\setlength{\floatsep}{8pt plus 2pt minus 2pt}
\setlength{\textfloatsep}{10pt plus 2pt minus 4pt}
\setlength{\intextsep}{8pt plus 2pt minus 2pt}

% ---- natbib (unless disabled) ----
\ifdefined\@nipsnonatbib\else
  \usepackage{natbib}
  \bibliographystyle{abbrvnat}
  \setlength{\bibsep}{2pt}
\fi

% Misc
\frenchspacing
\sloppy
